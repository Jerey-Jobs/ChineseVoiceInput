#!/bin/bash
set -e

# 升级 Pillow（transformers 依赖）
pip3 install --user --upgrade Pillow || true

# 安装 Python 依赖
pip3 install --user dashscope pynput faster-whisper huggingface-hub deepmultilingualpunctuation || true

# 创建配置目录
mkdir -p ~/.config/voice_typing

echo "VoiceType 安装完成！"
echo "使用命令 'voice-typing' 启动应用"
